# Arbiter LLM provider defaults.
# Copy this file to .env for local live-model testing. Never commit real keys.

# Safe default: no live model calls.
ARBITER_LLM_PROVIDER=none
ARBITER_LLM_TIMEOUT_SECONDS=30

# OpenAI-compatible OpenAI API example.
# ARBITER_LLM_PROVIDER=openai
# ARBITER_LLM_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=replace-with-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek example.
# ARBITER_LLM_PROVIDER=deepseek
# ARBITER_LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=replace-with-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_THINKING_ENABLED=false
# DEEPSEEK_REASONING_EFFORT=low

# Generic OpenAI-compatible provider example.
# ARBITER_LLM_PROVIDER=openai_compatible
# ARBITER_LLM_MODEL=replace-with-model-name
# ARBITER_LLM_API_KEY=replace-with-provider-api-key
# ARBITER_LLM_BASE_URL=https://provider.example/v1
